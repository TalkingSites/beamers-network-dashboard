# Copy this file to .env and fill in your values

# Get your Neon connection string from https://neon.tech → your project → Connection Details
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/beamers?sslmode=require"

# Auth.js — generate with `npx auth secret`
AUTH_SECRET=""
# Full deployed URL, e.g. https://wish.beamers.network (needed in production)
AUTH_URL=""

# Authentik OIDC client (Applications → Providers in Authentik admin)
AUTHENTIK_CLIENT_ID=""
AUTHENTIK_CLIENT_SECRET=""
AUTHENTIK_ISSUER=""
